# AI Image Generation API Keys
# Server-only secrets. Do not prefix with VITE_.
# MiniMax (Recommended - Default)
MINIMAX_API_KEY=your_minimax_api_key_here
# Google AI Studio (Gemini - Fallback)
GOOGLE_STUDIO_API_KEY=your_google_studio_api_key_here
# AI Provider Selection: 'minimax' | 'gemini' | 'auto'
VITE_AI_PROVIDER=minimax

# Optional server-side LLM planner for Burner Agent Mode
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_AGENT_MODEL=gpt-4.1-mini

# Burner Agent Mode (/agent) — default OFF. Set true only when testing or releasing.
# VITE_AGENT_MODE_ENABLED=true
# Optional dedicated Base RPC used by the browser-held burner wallet
# VITE_AGENT_MODE_RPC_URL=https://base.drpc.org

# Pinata IPFS Configuration (server-only)
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_KEY=your_pinata_secret_key_here
PINATA_JWT=your_pinata_jwt_token_here

# AI NFT Collection Contract Address (Base Mainnet)
VITE_AI_NFT_CONTRACT_ADDRESS=0xF8278421Df4312991616bd7F9D81EE9B52f1473c

# x402 Payment Configuration
X402_RECEIVING_ADDRESS=0x0000000000000000000000000000000000000000
X402_NETWORK=base
CDP_API_KEY_ID=your_cdp_api_key_id
CDP_API_KEY_SECRET=your_cdp_api_key_secret
# Use www to match production; apex basehub.fun redirects and breaks Vite /api proxy (browser follows 302 → CORS).
VITE_API_URL=https://www.basehub.fun

# Local `npm run dev` (Vite): /api/* is proxied to this origin (Vercel serverless is not bundled).
# Default: production www host (no redirect). Vite dev server defaults to port 5173 (set VITE_PORT to override).
# For local API: run `vercel dev` on :3000 and set DEV_API_PROXY=http://127.0.0.1:3000 (Vite stays on 5173 — no port clash).
DEV_API_PROXY=https://www.basehub.fun

# BaseScan API Key (for Wallet Analysis)
BASESCAN_API_KEY=your_basescan_api_key_here

# Supabase Configuration (Required for Featured Profiles)
# Get these from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# PumpHub Factory Contract Address (Base Mainnet)
# Deploy PumpHubFactory.sol contract first, then add the address here
VITE_PUMPHUB_FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# Base App bildirimleri (yalnızca sunucu — Vercel / backend; VITE ile kullanma)
# Base Dashboard → Settings → API Key. docs/BASE_APP_NOTIFICATIONS.md adım adım rehber.
# BASE_DASHBOARD_API_KEY=
# Base Dashboard’da kayıtlı uygulama URL’si (send + users isteklerinde app_url)
# BASE_APP_NOTIFICATIONS_APP_URL=https://www.basehub.fun
# Çoklu URL kitlesi (öncelik sırası). Aynı cüzdan birden fazla URL’de varsa script tekilleştirir.
# BASE_APP_NOTIFICATIONS_APP_URLS=https://www.basehub.fun,https://basehub.fun,https://basehub-alpha.vercel.app
#
# /admin panel — uzun rastgele string; asla repo/commit etme. Sunucuda doğrulanır.
# ADMIN_NOTIFICATIONS_SECRET=
# Gönderim geçmişi Supabase’e yazılır: supabase/migrations/admin_notification_broadcasts.sql çalıştır; SERVICE_KEY gerekli.
# Toplu bildirim metni (scripts/base-notifications-broadcast.py) — isteğe bağlı; title ≤30, message ≤200 karakter
# NOTIFY_TITLE=
# NOTIFY_MESSAGE=
